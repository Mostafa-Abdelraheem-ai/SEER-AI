APP_NAME=SEER-AI++ Backend
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
POSTGRES_DB=seer_ai_pp
POSTGRES_USER=seer
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql+psycopg://seer:change-this-postgres-password@db:5432/seer_ai_pp
CORS_ORIGINS=["http://YOUR_EC2_PUBLIC_IP","http://YOUR_DOMAIN"]
UPLOADS_DIR=/app/uploads
REPORTS_DIR=/app/outputs/reports
SEER_EMBEDDING_DIMENSION=384
